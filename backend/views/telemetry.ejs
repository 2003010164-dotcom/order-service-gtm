<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Telematics Data</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f6fb;
      margin: 0;
      padding: 0;
      color: #111;
    }

    /* Navbar */
    nav {
      background: #06122d;
      padding: 12px;
      display: flex;
      justify-content: center;
      gap: 30px;
    }
    nav a {
      color: white;
      text-decoration: none;
      font-weight: 600;
      font-size: 14px;
    }
    nav a:hover { text-decoration: underline; }

    .container {
      max-width: 1200px;
      margin: 25px auto;
      padding: 10px 20px 30px;
    }

    h2 {
      color: #06122d;
      margin: 0 0 10px;
      font-size: 22px;
    }

    .subtle {
      color: #555;
      font-size: 13px;
      margin-bottom: 12px;
      line-height: 1.35;
    }

    /* Table styling (like your reference image) */
    .tableWrap {
      background: #fff;
      border: 1px solid #d7dbea;
      border-radius: 6px;
      overflow: auto;
      box-shadow: 0px 4px 12px rgba(0,0,0,0.08);
    }

    table {
      border-collapse: collapse;
      width: 100%;
      min-width: 1100px;
      font-size: 13px;
    }

    thead th {
      background: #ffffff;
      color: #0b2fb3;
      font-weight: 800;
      text-align: left;
      padding: 10px 10px;
      border-bottom: 2px solid #cfd6ea;
      border-right: 1px solid #e2e6f3;
      white-space: nowrap;
    }

    tbody td {
      padding: 8px 10px;
      border-top: 1px solid #e2e6f3;
      border-right: 1px solid #e2e6f3;
      vertical-align: top;
      background: #fff;
    }

    tbody tr:nth-child(even) td {
      background: #f2f2f2;
    }

    input, select, textarea {
      width: 100%;
      font-size: 13px;
      padding: 7px 8px;
      border: 1px solid #cfd6ea;
      border-radius: 4px;
      outline: none;
      background: #fff;
    }

    input:focus, select:focus, textarea:focus {
      border-color: #7aa7ff;
      box-shadow: 0 0 0 3px rgba(122,167,255,0.18);
    }

    textarea {
      min-height: 60px;
      resize: vertical;
      line-height: 1.3;
    }

    .sensorGrid {
      display: grid;
      grid-template-columns: 1fr 0.8fr;
      gap: 8px;
      align-items: center;
    }

    /* Auto mode + live status */
    .autoBar {
      margin-top: 14px;
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .autoPill {
      background: #06122d;
      color: #fff;
      font-size: 12px;
      font-weight: 800;
      padding: 8px 12px;
      border-radius: 999px;
      white-space: nowrap;
    }

    .status {
      font-size: 13px;
      font-weight: 800;
      display: none;
      text-align: center;
      padding: 10px;
      border-radius: 10px;
      flex: 1;
    }

    .success {
      background: #e6fff0;
      color: #0a7a2f;
      border: 1px solid #b7f0cc;
    }

    .fail {
      background: #ffecec;
      color: #b30000;
      border: 1px solid #ffbaba;
    }

    .smallNote {
      font-size: 12px;
      color: #777;
      margin-top: 10px;
      line-height: 1.35;
    }

    /* Optional UI highlight when exceeded */
    .exceededCell {
      outline: 2px solid #b30000;
      outline-offset: -2px;
      background: #ffecec !important;
    }

    .okCell {
      outline: 2px solid #0a7a2f;
      outline-offset: -2px;
      background: #e6fff0 !important;
    }
  </style>
</head>

<body>
  <nav>
    <a href="/">Home</a>
    <a href="/orders">Orders</a>
    <a href="/telemetry">Telematics</a>
    <a href="/dashboard">Dashboard</a>
  </nav>

  <div class="container">
    <h2>Telematics Data (Single Vehicle)</h2>
    <div class="subtle">
      <b>No Submit button:</b> This page auto-checks thresholds instantly when you change values.
      If the value exceeds threshold, it auto-sends to Salesforce and creates a <b>Telematic Event</b> + <b>Case</b>.
      <br/>
      Thresholds (current): <b>EngineTempHigh &gt; 30</b>, <b>RPMSpike &gt; 6000</b>.
      Predictive Maintenance auto-sends on change (for dashboard needle).
    </div>

    <div class="tableWrap">
      <table>
        <thead>
          <tr>
            <th>Vehicle__c</th>
            <th>Event_Timestamp__c</th>
            <th>Event_Type__c</th>
            <th>Sensor_Value__c</th>
            <th>Severity__c</th>
            <th>Component__c</th>
            <th>Recommended_Action__c</th>
            <th>Status__c</th>
          </tr>
        </thead>

        <tbody>
          <tr>
            <td>
              <input id="vehicleSerialNumber" value="<%= model.vehicleSerialNumber %>" />
            </td>

            <td>
              <input id="eventTimestamp" type="datetime-local" value="<%= model.eventTimestamp %>" />
            </td>

            <td>
              <select id="eventType">
                <option value="RPMSpike" <%= model.eventType === 'RPMSpike' ? 'selected' : '' %>>RPMSpike</option>
                <option value="EngineTempHigh" <%= model.eventType === 'EngineTempHigh' ? 'selected' : '' %>>EngineTempHigh</option>
                <option value="Predictive Maintenance" <%= model.eventType === 'Predictive Maintenance' ? 'selected' : '' %>>Predictive Maintenance</option>
              </select>
            </td>

            <td id="sensorCell">
              <div class="sensorGrid">
                <input id="sensorValueNumber" type="number" value="<%= model.sensorValueNumber %>" />
                <input id="sensorUnit" value="<%= model.sensorUnit %>" />
              </div>
            </td>

            <td>
              <select id="severity">
                <option value="Low" <%= model.severity === 'Low' ? 'selected' : '' %>>Low</option>
                <option value="Medium" <%= model.severity === 'Medium' ? 'selected' : '' %>>Medium</option>
                <option value="High" <%= model.severity === 'High' ? 'selected' : '' %>>High</option>
                <option value="Critical" <%= model.severity === 'Critical' ? 'selected' : '' %>>Critical</option>
              </select>
            </td>

            <td>
              <input id="component" value="<%= model.component %>" />
            </td>

            <td>
              <input id="recommendedActionShort" value="<%= model.recommendedAction %>" style="margin-bottom:8px;" />
              <textarea id="recommendedAction"><%= model.recommendedAction %></textarea>
            </td>

            <td>
              <select id="status">
                <option value="New" <%= model.status === 'New' ? 'selected' : '' %>>New</option>
                <option value="In Progress" <%= model.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                <option value="Resolved" <%= model.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
              </select>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Auto mode bar + live status -->
    <div class="autoBar">
      <div class="autoPill">AUTO MODE: ON</div>

      <div class="status success" id="successBox">✅</div>
      <div class="status fail" id="failBox">❌</div>
    </div>

    <div class="smallNote" id="resultText"></div>

    <div class="smallNote">
      Tips:
      <br/>• EngineTempHigh: set <b>31</b> → should auto-create a Case.
      <br/>• RPMSpike: set <b>6001</b> → should auto-create a Case.
      <br/>• Predictive Maintenance: set <b>55</b> → auto-creates event (dashboard needle updates).
    </div>
  </div>

  <script>
    // UI-side thresholds (same as Salesforce example)
    const THRESHOLDS = {
      EngineTempHigh: 30,
      RPMSpike: 6000
      // Predictive Maintenance: no threshold (always send to update dashboard needle)
    };

    // Debounce to avoid calling Salesforce on every keystroke
    let debounceTimer = null;

    // Prevent spamming Cases: only trigger when crossing from NOT exceeded -> exceeded
    let lastExceeded = false;

    // Avoid sending duplicate payload repeatedly
    let lastSentSignature = "";

    function el(id) { return document.getElementById(id); }

    function showStatus(type, message) {
      const successBox = el("successBox");
      const failBox = el("failBox");
      const resultText = el("resultText");

      successBox.style.display = "none";
      failBox.style.display = "none";

      if (type === "success") successBox.style.display = "block";
      if (type === "fail") failBox.style.display = "block";

      resultText.innerText = message || "";
    }

    function buildPayload() {
      return {
        vehicleSerialNumber: el("vehicleSerialNumber").value.trim(),
        eventTimestamp: el("eventTimestamp").value,
        eventType: el("eventType").value,
        sensorValueNumber: Number(el("sensorValueNumber").value || 0),
        sensorUnit: el("sensorUnit").value.trim(),
        severity: el("severity").value,
        component: el("component").value.trim(),
        recommendedAction: el("recommendedAction").value.trim(),
        status: el("status").value
      };
    }

    function thresholdFor(eventType) {
      return THRESHOLDS[eventType]; // undefined for Predictive Maintenance
    }

    function signature(payload) {
      return [
        payload.vehicleSerialNumber,
        payload.eventType,
        payload.sensorValueNumber,
        payload.sensorUnit,
        payload.severity,
        payload.component,
        payload.status
      ].join("|");
    }

    function updateSensorCellUI(state) {
      const cell = el("sensorCell");
      cell.classList.remove("exceededCell", "okCell");
      if (state === "exceeded") cell.classList.add("exceededCell");
      if (state === "ok") cell.classList.add("okCell");
    }

    async function sendToSalesforce(payload, reasonText) {
      try {
        const res = await fetch("/send-telemetry-to-crm", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });

        const data = await res.json();

        if (res.ok && data.success) {
          let msg = reasonText || (data.message || "Sent");

          if (data.telematicEventId) msg += " | Telematic Event: " + data.telematicEventId;
          if (data.caseId) msg += " | Case: " + data.caseId;

          showStatus("success", msg);
        } else {
          showStatus("fail", (data && (data.message || JSON.stringify(data))) || "Salesforce Error");
          console.log("Salesforce Error:", data);
        }
      } catch (err) {
        showStatus("fail", err.message);
        console.log("Error:", err.message);
      }
    }

    function onFieldChange() {
      clearTimeout(debounceTimer);

      debounceTimer = setTimeout(async () => {
        const payload = buildPayload();
        const t = thresholdFor(payload.eventType);

        // Predictive Maintenance: always send on change (dashboard needle updates)
        if (payload.eventType === "Predictive Maintenance") {
          updateSensorCellUI(""); // no threshold styling

          const sig = signature(payload);
          if (sig !== lastSentSignature) {
            lastSentSignature = sig;
            lastExceeded = false;

            await sendToSalesforce(payload, "📈 Predictive Maintenance changed → auto-sent to Salesforce.");
          } else {
            showStatus("success", "📈 Predictive Maintenance unchanged (not resent).");
          }
          return;
        }

        // No threshold defined for this event type
        if (t === undefined || t === null) {
          updateSensorCellUI("");
          lastExceeded = false;
          showStatus("success", "ℹ️ No threshold configured for this event type. Not auto-sending.");
          return;
        }

        // Threshold defined: compare
        const exceeded = payload.sensorValueNumber > t;

        if (exceeded) {
          updateSensorCellUI("exceeded");

          // Trigger only on crossing to exceeded
          if (!lastExceeded) {
            lastExceeded = true;
            const sig = signature(payload);

            if (sig !== lastSentSignature) {
              lastSentSignature = sig;
              await sendToSalesforce(payload, `⚠️ Exceeded threshold (${payload.eventType} > ${t}) → auto-sent.`);
            } else {
              showStatus("success", `⚠️ Exceeded threshold (${payload.eventType} > ${t}) (already sent for same values).`);
            }
          } else {
            showStatus("success", `⚠️ Still above threshold (${payload.eventType} > ${t}). Reduce below threshold then exceed again to create a new Case.`);
          }
        } else {
          updateSensorCellUI("ok");
          lastExceeded = false;
          showStatus("success", `✅ Within threshold (<= ${t}). No auto-send.`);
        }
      }, 500); // 500ms debounce
    }

    window.addEventListener("load", () => {
      const ids = [
        "vehicleSerialNumber",
        "eventTimestamp",
        "eventType",
        "sensorValueNumber",
        "sensorUnit",
        "severity",
        "component",
        "recommendedAction",
        "status"
      ];

      ids.forEach(id => {
        const element = el(id);
        if (!element) return;
        element.addEventListener("input", onFieldChange);
        element.addEventListener("change", onFieldChange);
      });

      // Initial evaluation on load
      onFieldChange();
    });
  </script>
</body>
</html>
