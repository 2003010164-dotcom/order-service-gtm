<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Telematics Data</title>

  <style>
  /* ===== Telematics UI (inspired by enterprise “connection + grid” screens) ===== */

/* Theme tokens (still your palette, but arranged in SaaS-style neutrals) */
:root{
  --bg-app: #f5f7fb;              /* app background */
  --panel: #ffffff;               /* white panels */
  --text: #0B2E33;                /* strong text */
  --muted: rgba(11,46,51,.70);    /* muted text */
  --line: rgba(11,46,51,.12);     /* borders */
  --line2: rgba(11,46,51,.18);    /* stronger borders */
  --accent: #4F7C82;              /* accent */
  --soft: #B8E3E9;                /* soft tint */
  --soft2:#93B1B5;                /* secondary soft */
  --shadow: 0 10px 26px rgba(11,46,51,.08);
  --shadow2: 0 6px 14px rgba(11,46,51,.06);
}

*{ box-sizing:border-box; }

body{
  font-family: Arial, sans-serif;
  background: var(--bg-app);
  margin: 0;
  padding: 0;
  color: var(--text);
}

/* Keep navbar styling if you later enable it */
nav{
  background: #0B2E33;
  padding: 12px;
  display:flex;
  justify-content:center;
  gap:30px;
  position: sticky;
  top: 0;
  z-index: 50;
  border-bottom: 1px solid rgba(184,227,233,.16);
}
nav a{
  color: #B8E3E9;
  text-decoration:none;
  font-weight:700;
  font-size:14px;
}
nav a:hover{ text-decoration:underline; }

/* Container becomes a “details panel + data grid” layout */
.container{
  max-width: 1220px;
  margin: 22px auto;
  padding: 12px 16px 28px;

  display: grid;
  grid-template-columns: 330px 1fr;
  gap: 14px;
  align-items: start;
}

/* Title like a SaaS page heading */
h2{
  grid-column: 1 / -1;
  margin: 0 0 6px;
  font-size: 18px;
  font-weight: 900;
  letter-spacing: .2px;
  color: var(--text);
  display:flex;
  align-items:center;
  gap:10px;
}
h2::before{
  content:"";
  width:10px;
  height:10px;
  border-radius: 50%;
  background: #38c172;              /* live dot feel */
  box-shadow: 0 0 0 4px rgba(56,193,114,.14);
  display:inline-block;
}

/* Left “Connection details” card (uses your .subtle block) */
.subtle{
  grid-column: 1;
  margin: 0;
  padding: 14px 14px;

  border: 1px solid var(--line);
  border-radius: 10px;
  background: var(--panel);
  box-shadow: var(--shadow2);

  font-size: 12.5px;
  line-height: 1.45;
  color: var(--muted);

  position: relative;
}
.subtle b{ color: var(--text); }

/* Make the left card feel like a “Connection: …” panel header */
.subtle::before{
  content: "Connection Details";
  display:block;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: .5px;
  text-transform: uppercase;
  color: rgba(11,46,51,.55);
  margin-bottom: 10px;
}

/* Auto bar sits under the left panel */
.autoBar{
  grid-column: 1;
  margin-top: 0;
  display:flex;
  gap:10px;
  align-items:center;

  padding: 12px 12px;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: var(--panel);
  box-shadow: var(--shadow2);
}

/* Auto pill becomes a “toggle-like” label */
.autoPill{
  background: rgba(11,46,51,.92);
  color: #fff;
  font-size: 11px;
  font-weight: 900;
  padding: 8px 10px;
  border-radius: 999px;
  white-space: nowrap;
  letter-spacing: .4px;
  display:flex;
  align-items:center;
  gap:8px;
}
.autoPill::before{
  content:"";
  width:8px;
  height:8px;
  border-radius:50%;
  background:#38c172;
  box-shadow: 0 0 0 0 rgba(56,193,114,.45);
  animation: pulse 1.6s infinite;
}
@keyframes pulse{
  0%{ box-shadow:0 0 0 0 rgba(56,193,114,.45); }
  70%{ box-shadow:0 0 0 10px rgba(56,193,114,0); }
  100%{ box-shadow:0 0 0 0 rgba(56,193,114,0); }
}

/* Status boxes align nicely inside auto bar */
.status{
  font-size: 12px;
  font-weight: 900;
  display:none;
  text-align:center;
  padding: 9px 10px;
  border-radius: 10px;
  flex: 1;
}

/* Keep your semantic colors for success/fail */
.success{
  background:#e6fff0;
  color:#0a7a2f;
  border:1px solid #b7f0cc;
}
.fail{
  background:#ffecec;
  color:#b30000;
  border:1px solid #ffbaba;
}

/* Notes on left side (like “help / tips” section) */
.smallNote{
  grid-column: 1;
  font-size: 12px;
  color: rgba(11,46,51,.70);
  line-height: 1.45;

  padding: 12px 12px;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: var(--panel);
  box-shadow: var(--shadow2);
}

/* Make the resultText feel like a live status log */
#resultText{
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
  color: rgba(11,46,51,.78);
}

/* Right panel: “data grid” */
.tableWrap{
  grid-column: 2;
  grid-row: 2 / span 6; /* table spans alongside the left cards */
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 10px;
  overflow: auto;
  box-shadow: var(--shadow);
  position: relative;
}

/* Data grid top padding (like toolbar spacing, without adding HTML) */
.tableWrap{
  padding-top: 6px;
}

/* Table styling like enterprise grids */
table{
  border-collapse: separate;
  border-spacing: 0;
  width: 100%;
  min-width: 1100px;
  font-size: 12.5px;
}

/* Sticky header like the inspiration grid */
thead th{
  position: sticky;
  top: 0;
  z-index: 10;

  background: #ffffff;
  color: rgba(11,46,51,.85);
  font-weight: 900;
  text-align: left;
  padding: 10px 12px;

  border-bottom: 1px solid var(--line2);
  border-right: 1px solid rgba(11,46,51,.08);
  white-space: nowrap;
}

/* Subtle “blue-ish” header accent line */
thead th:first-child{
  border-left: 3px solid var(--accent);
}

/* Body cells + row lines */
tbody td{
  padding: 10px 12px;
  border-top: 1px solid rgba(11,46,51,.06);
  border-right: 1px solid rgba(11,46,51,.05);
  vertical-align: middle;
  background: #fff;
}

/* Zebra striping similar to SaaS tables */
tbody tr:nth-child(even) td{
  background: rgba(245,247,251,.9);
}

/* Hover row */
tbody tr:hover td{
  background: rgba(184,227,233,.18);
}

/* Form controls look like grid editors */
input, select, textarea{
  width: 100%;
  font-size: 12.5px;
  padding: 8px 9px;
  border: 1px solid rgba(11,46,51,.14);
  border-radius: 6px;
  outline: none;
  background: #ffffff;
  color: var(--text);
}

/* Numeric alignment like telemetry consoles */
input[type="number"],
input[type="datetime-local"]{
  font-variant-numeric: tabular-nums;
}

/* Focus style */
input:focus, select:focus, textarea:focus{
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(79,124,130,.16);
}

/* Textarea */
textarea{
  min-height: 70px;
  resize: vertical;
  line-height: 1.35;
}

/* Sensor cell grid stays intact but looks tighter */
.sensorGrid{
  display:grid;
  grid-template-columns: 1fr .85fr;
  gap: 8px;
  align-items:center;
}

/* Threshold highlights: look like “flagged row/cell” */
.exceededCell{
  outline: 2px solid rgba(179,0,0,.65);
  outline-offset: -2px;
  background: rgba(255,236,236,.70) !important;
}
.okCell{
  outline: 2px solid rgba(10,122,47,.55);
  outline-offset: -2px;
  background: rgba(230,255,240,.80) !important;
}

/* Responsive: stack panels on small screens */
@media (max-width: 980px){
  .container{
    grid-template-columns: 1fr;
  }
  .tableWrap{
    grid-column: 1;
    grid-row: auto;
  }
}
</style>
</head>

<body>
  

  <div class="container">
    <h2>Telematics Data </h2>
    <div class="subtle">
      <b>No Submit button:</b> This page auto-checks thresholds instantly when you change values.
      If the value exceeds threshold, it auto-sends to Salesforce and creates a <b>Telematic Event</b> + <b>Case</b>.
      <br/>
      Thresholds (current): <b>EngineTempHigh &gt; 30</b>, <b>RPMSpike &gt; 6000</b>.
      Predictive Maintenance auto-sends on change (for dashboard needle).
    </div>

    <div class="tableWrap">
      <table>
        <thead>
          <tr>
            <th>Vehicle__c</th>
            <th>Event_Timestamp__c</th>
            <th>Event_Type__c</th>
            <th>Sensor_Value__c</th>
            <th>Severity__c</th>
            <th>Component__c</th>
            <th>Recommended_Action__c</th>
            <th>Status__c</th>
          </tr>
        </thead>

        <tbody>
          <tr>
            <td>
              <input id="vehicleSerialNumber" value="<%= model.vehicleSerialNumber %>" />
            </td>

            <td>
              <input id="eventTimestamp" type="datetime-local" value="<%= model.eventTimestamp %>" />
            </td>

            <td>
              <select id="eventType">
                <option value="RPMSpike" <%= model.eventType === 'RPMSpike' ? 'selected' : '' %>>RPMSpike</option>
                <option value="EngineTempHigh" <%= model.eventType === 'EngineTempHigh' ? 'selected' : '' %>>EngineTempHigh</option>
                <option value="Predictive Maintenance" <%= model.eventType === 'Predictive Maintenance' ? 'selected' : '' %>>Predictive Maintenance</option>
              </select>
            </td>

            <td id="sensorCell">
              <div class="sensorGrid">
                <input id="sensorValueNumber" type="number" value="<%= model.sensorValueNumber %>" />
                <input id="sensorUnit" value="<%= model.sensorUnit %>" />
              </div>
            </td>

            <td>
              <select id="severity">
                <option value="Low" <%= model.severity === 'Low' ? 'selected' : '' %>>Low</option>
                <option value="Medium" <%= model.severity === 'Medium' ? 'selected' : '' %>>Medium</option>
                <option value="High" <%= model.severity === 'High' ? 'selected' : '' %>>High</option>
                <option value="Critical" <%= model.severity === 'Critical' ? 'selected' : '' %>>Critical</option>
              </select>
            </td>

            <td>
              <input id="component" value="<%= model.component %>" />
            </td>

            <td>
              <input id="recommendedActionShort" value="<%= model.recommendedAction %>" style="margin-bottom:8px;" />
              <textarea id="recommendedAction"><%= model.recommendedAction %></textarea>
            </td>

            <td>
              <select id="status">
                <option value="New" <%= model.status === 'New' ? 'selected' : '' %>>New</option>
                <option value="In Progress" <%= model.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                <option value="Resolved" <%= model.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
              </select>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Auto mode bar + live status -->
    <div class="autoBar">
      <div class="autoPill">AUTO MODE: ON</div>

      <div class="status success" id="successBox">✅</div>
      <div class="status fail" id="failBox">❌</div>
    </div>

    <div class="smallNote" id="resultText"></div>

    <div class="smallNote">
      Tips:
      <br/>• EngineTempHigh: set <b>31</b> → should auto-create a Case.
      <br/>• RPMSpike: set <b>6001</b> → should auto-create a Case.
      <br/>• Predictive Maintenance: set <b>55</b> → auto-creates event (dashboard needle updates).
    </div>
  </div>

  <script>
    // UI-side thresholds (same as Salesforce example)
    const THRESHOLDS = {
      EngineTempHigh: 30,
      RPMSpike: 6000
      // Predictive Maintenance: no threshold (always send to update dashboard needle)
    };

    // Debounce to avoid calling Salesforce on every keystroke
    let debounceTimer = null;

    // Prevent spamming Cases: only trigger when crossing from NOT exceeded -> exceeded
    let lastExceeded = false;

    // Avoid sending duplicate payload repeatedly
    let lastSentSignature = "";

    function el(id) { return document.getElementById(id); }

    function showStatus(type, message) {
      const successBox = el("successBox");
      const failBox = el("failBox");
      const resultText = el("resultText");

      successBox.style.display = "none";
      failBox.style.display = "none";

      if (type === "success") successBox.style.display = "block";
      if (type === "fail") failBox.style.display = "block";

      resultText.innerText = message || "";
    }

    function buildPayload() {
      return {
        vehicleSerialNumber: el("vehicleSerialNumber").value.trim(),
        eventTimestamp: el("eventTimestamp").value,
        eventType: el("eventType").value,
        sensorValueNumber: Number(el("sensorValueNumber").value || 0),
        sensorUnit: el("sensorUnit").value.trim(),
        severity: el("severity").value,
        component: el("component").value.trim(),
        recommendedAction: el("recommendedAction").value.trim(),
        status: el("status").value
      };
    }

    function thresholdFor(eventType) {
      return THRESHOLDS[eventType]; // undefined for Predictive Maintenance
    }

    function signature(payload) {
      return [
        payload.vehicleSerialNumber,
        payload.eventType,
        payload.sensorValueNumber,
        payload.sensorUnit,
        payload.severity,
        payload.component,
        payload.status
      ].join("|");
    }

    function updateSensorCellUI(state) {
      const cell = el("sensorCell");
      cell.classList.remove("exceededCell", "okCell");
      if (state === "exceeded") cell.classList.add("exceededCell");
      if (state === "ok") cell.classList.add("okCell");
    }

    async function sendToSalesforce(payload, reasonText) {
      try {
        const res = await fetch("/send-telemetry-to-crm", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });

        const data = await res.json();

        if (res.ok && data.success) {
          let msg = reasonText || (data.message || "Sent");

          if (data.telematicEventId) msg += " | Telematic Event: " + data.telematicEventId;
          if (data.caseId) msg += " | Case: " + data.caseId;

          showStatus("success", msg);
        } else {
          showStatus("fail", (data && (data.message || JSON.stringify(data))) || "Salesforce Error");
          console.log("Salesforce Error:", data);
        }
      } catch (err) {
        showStatus("fail", err.message);
        console.log("Error:", err.message);
      }
    }

    function onFieldChange() {
      clearTimeout(debounceTimer);

      debounceTimer = setTimeout(async () => {
        const payload = buildPayload();
        const t = thresholdFor(payload.eventType);

        // Predictive Maintenance: always send on change (dashboard needle updates)
        if (payload.eventType === "Predictive Maintenance") {
          updateSensorCellUI(""); // no threshold styling

          const sig = signature(payload);
          if (sig !== lastSentSignature) {
            lastSentSignature = sig;
            lastExceeded = false;

            await sendToSalesforce(payload, "📈 Predictive Maintenance changed → auto-sent to Salesforce.");
          } else {
            showStatus("success", "📈 Predictive Maintenance unchanged (not resent).");
          }
          return;
        }

        // No threshold defined for this event type
        if (t === undefined || t === null) {
          updateSensorCellUI("");
          lastExceeded = false;
          showStatus("success", "ℹ️ No threshold configured for this event type. Not auto-sending.");
          return;
        }

        // Threshold defined: compare
        const exceeded = payload.sensorValueNumber > t;

        if (exceeded) {
          updateSensorCellUI("exceeded");

          // Trigger only on crossing to exceeded
          if (!lastExceeded) {
            lastExceeded = true;
            const sig = signature(payload);

            if (sig !== lastSentSignature) {
              lastSentSignature = sig;
              await sendToSalesforce(payload, `⚠️ Exceeded threshold (${payload.eventType} > ${t}) → auto-sent.`);
            } else {
              showStatus("success", `⚠️ Exceeded threshold (${payload.eventType} > ${t}) (already sent for same values).`);
            }
          } else {
            showStatus("success", `⚠️ Still above threshold (${payload.eventType} > ${t}). Reduce below threshold then exceed again to create a new Case.`);
          }
        } else {
          updateSensorCellUI("ok");
          lastExceeded = false;
          showStatus("success", `✅ Within threshold (<= ${t}). No auto-send.`);
        }
      }, 500); // 500ms debounce
    }

    window.addEventListener("load", () => {
      const ids = [
        "vehicleSerialNumber",
        "eventTimestamp",
        "eventType",
        "sensorValueNumber",
        "sensorUnit",
        "severity",
        "component",
        "recommendedAction",
        "status"
      ];

      ids.forEach(id => {
        const element = el(id);
        if (!element) return;
        element.addEventListener("input", onFieldChange);
        element.addEventListener("change", onFieldChange);
      });

      // Initial evaluation on load
      onFieldChange();
    });
  </script>
</body>
</html>
