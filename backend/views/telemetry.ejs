<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Telematics Data</title>

  <style>
  /* (UNCHANGED CSS — KEEPING AS IT IS) */
  /* your full CSS remains same */
  </style>
</head>

<body>
  <div class="container">
    <h2>Telematics Data </h2>

    <!-- ✅ UPDATED HEADER DESCRIPTION -->
    <div class="subtle">
      <b>Real-Time Telematics Monitoring:</b> This dashboard simulates live vehicle data streaming from onboard sensors (ECU).
      Sensor values are continuously evaluated against predefined thresholds without manual submission.
      <br/><br/>
      If any parameter exceeds its threshold, the system automatically creates a <b>Telematics Event</b> and triggers a <b>Service Case</b> in Salesforce.
      <br/><br/>
      <b>Active Monitoring Thresholds:</b> Engine Temperature &gt; 30°C, RPM Spike &gt; 6000 RPM.
      Predictive Maintenance events are auto-generated based on real-time data changes for proactive diagnostics.
    </div>

    <div class="tableWrap">
      <table>
        <thead>
          <tr>
            <th>Vehicle__c</th>
            <th>Event_Timestamp__c</th>
            <th>Event_Type__c</th>
            <th>Sensor_Value__c</th>
            <th>Severity__c</th>
            <th>Component__c</th>
            <th>Recommended_Action__c</th>
            <th>Status__c</th>
          </tr>
        </thead>

        <tbody>
          <tr>
            <td>
              <input id="vehicleSerialNumber" value="<%= model.vehicleSerialNumber %>" />
            </td>

            <td>
              <input id="eventTimestamp" type="datetime-local" value="<%= model.eventTimestamp %>" />
            </td>

            <td>
              <select id="eventType">
                <option value="RPMSpike" <%= model.eventType === 'RPMSpike' ? 'selected' : '' %>>RPMSpike</option>
                <option value="EngineTempHigh" <%= model.eventType === 'EngineTempHigh' ? 'selected' : '' %>>EngineTempHigh</option>
                <option value="Predictive Maintenance" <%= model.eventType === 'Predictive Maintenance' ? 'selected' : '' %>>Predictive Maintenance</option>
              </select>
            </td>

            <td id="sensorCell">
              <div class="sensorGrid">
                <input id="sensorValueNumber" type="number" value="<%= model.sensorValueNumber %>" />
                <input id="sensorUnit" value="<%= model.sensorUnit %>" />
              </div>
            </td>

            <td>
              <select id="severity">
                <option value="Low" <%= model.severity === 'Low' ? 'selected' : '' %>>Low</option>
                <option value="Medium" <%= model.severity === 'Medium' ? 'selected' : '' %>>Medium</option>
                <option value="High" <%= model.severity === 'High' ? 'selected' : '' %>>High</option>
                <option value="Critical" <%= model.severity === 'Critical' ? 'selected' : '' %>>Critical</option>
              </select>
            </td>

            <td>
              <input id="component" value="<%= model.component %>" />
            </td>

            <!-- ✅ UPDATED RECOMMENDED ACTION -->
            <td>
              <input id="recommendedActionShort" value="<%= model.recommendedAction || 'Incident logged for analysis' %>" style="margin-bottom:8px;" />
              <textarea id="recommendedAction"><%= model.recommendedAction || 'Detected abnormal vehicle behavior. This may indicate aggressive driving patterns or potential component stress. Further inspection is recommended if the condition persists.' %></textarea>
            </td>

            <td>
              <select id="status">
                <option value="New" <%= model.status === 'New' ? 'selected' : '' %>>New</option>
                <option value="In Progress" <%= model.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                <option value="Resolved" <%= model.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
              </select>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- ✅ UPDATED AUTO MODE -->
    <div class="autoBar">
      <div class="autoPill">REAL-TIME MONITORING: ACTIVE</div>

      <div class="status success" id="successBox">✅</div>
      <div class="status fail" id="failBox">❌</div>
    </div>

    <div class="smallNote" id="resultText"></div>

    <!-- ✅ UPDATED INSIGHTS SECTION -->
    <div class="smallNote">
      <b>System Insights & Simulation Controls:</b>
      <br/>• Increasing engine temperature beyond threshold will automatically trigger a diagnostic case.
      <br/>• RPM values exceeding safe limits simulate high engine load or aggressive driving conditions.
      <br/>• Predictive maintenance events are generated from continuous sensor data analysis.
      <br/><br/>
      This simulation reflects how real-world connected vehicle systems proactively detect, analyze, and respond to potential failures.
    </div>
  </div>

  <script>
    // (UNCHANGED LOGIC — ONLY TEXT UPDATED BELOW)

    function showStatus(type, message) {
      const successBox = document.getElementById("successBox");
      const failBox = document.getElementById("failBox");
      const resultText = document.getElementById("resultText");

      successBox.style.display = "none";
      failBox.style.display = "none";

      if (type === "success") successBox.style.display = "block";
      if (type === "fail") failBox.style.display = "block";

      resultText.innerText = message || "";
    }

    // ✅ UPDATED MESSAGES ONLY

    // Replace messages inside your existing logic:

    // Within threshold
    // OLD → showStatus("success", `✅ Within threshold (<= ${t}). No auto-send.`);
    // NEW:
    // showStatus("success", `✅ All vehicle parameters are within normal operating range. No anomalies detected.`);

    // Exceeded threshold
    // OLD → auto-sent message
    // NEW:
    // `⚠️ Threshold breach detected (${payload.eventType} > ${t}). Event logged and case created for diagnostic action.`

    // Still exceeded
    // NEW:
    // `⚠️ Parameter remains above safe operating limit. System is monitoring for further changes.`

    // Predictive maintenance
    // NEW:
    // `📈 Predictive maintenance event generated based on live data trends. Sent to Salesforce for proactive analysis.`

    // Unchanged predictive
    // NEW:
    // `📈 No significant change detected in predictive metrics.`

  </script>
</body>
</html>
