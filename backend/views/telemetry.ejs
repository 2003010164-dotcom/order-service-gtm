<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Telematics Data</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f6fb;
      margin: 0;
      padding: 0;
      color: #111;
    }

    /* Navbar */
    nav {
      background: #06122d;
      padding: 12px;
      display: flex;
      justify-content: center;
      gap: 30px;
    }
    nav a {
      color: white;
      text-decoration: none;
      font-weight: 600;
      font-size: 14px;
    }
    nav a:hover { text-decoration: underline; }

    .container {
      max-width: 1200px;
      margin: 25px auto;
      padding: 10px 20px 30px;
    }

    h2 {
      color: #06122d;
      margin: 0 0 12px;
      font-size: 22px;
    }

    .subtle {
      color: #555;
      font-size: 13px;
      margin-bottom: 14px;
      line-height: 1.35;
    }

    /* Table styling (like reference image) */
    .tableWrap {
      background: #fff;
      border: 1px solid #d7dbea;
      border-radius: 6px;
      overflow: auto;
      box-shadow: 0px 4px 12px rgba(0,0,0,0.08);
    }

    table {
      border-collapse: collapse;
      width: 100%;
      min-width: 1100px; /* allow horizontal scroll like report tables */
      font-size: 13px;
    }

    thead th {
      background: #ffffff;
      color: #0b2fb3; /* blue header like reference */
      font-weight: 800;
      text-align: left;
      padding: 10px 10px;
      border-bottom: 2px solid #cfd6ea;
      border-right: 1px solid #e2e6f3;
      white-space: nowrap;
    }

    tbody td {
      padding: 8px 10px;
      border-top: 1px solid #e2e6f3;
      border-right: 1px solid #e2e6f3;
      vertical-align: top;
      background: #fff;
    }

    /* alternating row shading */
    tbody tr:nth-child(even) td {
      background: #f2f2f2;
    }

    /* inputs inside table */
    input, select, textarea {
      width: 100%;
      font-size: 13px;
      padding: 7px 8px;
      border: 1px solid #cfd6ea;
      border-radius: 4px;
      outline: none;
      background: #fff;
    }
    input:focus, select:focus, textarea:focus {
      border-color: #7aa7ff;
      box-shadow: 0 0 0 3px rgba(122,167,255,0.18);
    }

    textarea {
      min-height: 60px;
      resize: vertical;
      line-height: 1.3;
    }

    /* sensor cell with 2 inputs */
    .sensorGrid {
      display: grid;
      grid-template-columns: 1fr 0.8fr;
      gap: 8px;
      align-items: center;
    }

    /* Submit + status */
    .actions {
      margin-top: 14px;
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .btn {
      background: #06122d;
      color: white;
      padding: 10px 12px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 800;
      font-size: 14px;
      width: 320px;
    }
    .btn:hover { background: #0a1d4b; }

    .status {
      font-size: 13px;
      font-weight: 800;
      display: none;
      text-align: center;
      padding: 10px;
      border-radius: 10px;
      flex: 1;
    }
    .success {
      background: #e6fff0;
      color: #0a7a2f;
      border: 1px solid #b7f0cc;
    }
    .fail {
      background: #ffecec;
      color: #b30000;
      border: 1px solid #ffbaba;
    }

    .smallNote {
      font-size: 12px;
      color: #777;
      margin-top: 10px;
      line-height: 1.35;
    }
  </style>
</head>

<body>
  <nav>
    <a href="/">Home</a>
    <a href="/orders">Orders</a>
    <a href="/telemetry">Telematics</a>
    <a href="/dashboard">Dashboard</a>
  </nav>

  <div class="container">
    <h2>Telematics Data (Single Vehicle)</h2>
    <div class="subtle">
      This page shows a single (latest) vehicle record. Edit the fields and click <b>Submit</b> to send telemetry to Salesforce.
      <br/>
      Threshold examples (checked in Salesforce REST service): <b>EngineTempHigh &gt; 30</b>, <b>RPMSpike &gt; 6000</b>.
      Predictive Maintenance creates a Telematic Event (needle uses its sensor value).
    </div>

    <div class="tableWrap">
      <table>
        <thead>
          <tr>
            <th>Vehicle__c</th>
            <th>Event_Timestamp__c</th>
            <th>Event_Type__c</th>
            <th>Sensor_Value__c</th>
            <th>Severity__c</th>
            <th>Component__c</th>
            <th>Recommended_Action__c</th>
            <th>Status__c</th>
          </tr>
        </thead>

        <tbody>
          <!-- Single row only -->
          <tr>
            <td>
              <input id="vehicleSerialNumber" value="<%= model.vehicleSerialNumber %>" />
            </td>

            <td>
              <input id="eventTimestamp" type="datetime-local" value="<%= model.eventTimestamp %>" />
            </td>

            <td>
              <select id="eventType">
                <option value="RPMSpike" <%= model.eventType === 'RPMSpike' ? 'selected' : '' %>>RPMSpike</option>
                <option value="EngineTempHigh" <%= model.eventType === 'EngineTempHigh' ? 'selected' : '' %>>EngineTempHigh</option>
                <option value="Predictive Maintenance" <%= model.eventType === 'Predictive Maintenance' ? 'selected' : '' %>>Predictive Maintenance</option>
              </select>
            </td>

            <td>
              <div class="sensorGrid">
                <input id="sensorValueNumber" type="number" value="<%= model.sensorValueNumber %>" />
                <input id="sensorUnit" value="<%= model.sensorUnit %>" />
              </div>
            </td>

            <td>
              <select id="severity">
                <option value="Low" <%= model.severity === 'Low' ? 'selected' : '' %>>Low</option>
                <option value="Medium" <%= model.severity === 'Medium' ? 'selected' : '' %>>Medium</option>
                <option value="High" <%= model.severity === 'High' ? 'selected' : '' %>>High</option>
                <option value="Critical" <%= model.severity === 'Critical' ? 'selected' : '' %>>Critical</option>
              </select>
            </td>

            <td>
              <input id="component" value="<%= model.component %>" />
            </td>

            <td>
              <!-- keep the short input (not used by JS, but kept as per your earlier page) -->
              <input id="recommendedActionShort" value="<%= model.recommendedAction %>" style="margin-bottom:8px;" />
              <textarea id="recommendedAction"><%= model.recommendedAction %></textarea>
            </td>

            <td>
              <select id="status">
                <option value="New" <%= model.status === 'New' ? 'selected' : '' %>>New</option>
                <option value="In Progress" <%= model.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                <option value="Resolved" <%= model.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
              </select>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="actions">
      <button class="btn" onclick="sendTelemetry()">
        Submit (Send to Salesforce)
      </button>

      <div class="status success" id="successBox">
        ✅ Sent to Salesforce (Telematic Event created)
      </div>

      <div class="status fail" id="failBox">
        ❌ Failed to send
      </div>
    </div>

    <div class="smallNote" id="resultText"></div>

    <div class="smallNote">
      Tips:
      <br/>• Choose <b>EngineTempHigh</b> and set sensor value to <b>31</b> → Case should be created.
      <br/>• Choose <b>RPMSpike</b> and set sensor value to <b>6001</b> → Case should be created.
      <br/>• Choose <b>Predictive Maintenance</b> and set sensor value to <b>55</b> → dashboard needle should point to 55.
    </div>
  </div>

  <script>
    async function sendTelemetry() {
      document.getElementById("successBox").style.display = "none";
      document.getElementById("failBox").style.display = "none";
      document.getElementById("resultText").innerText = "";

      const payload = {
        vehicleSerialNumber: document.getElementById("vehicleSerialNumber").value.trim(),
        eventTimestamp: document.getElementById("eventTimestamp").value,
        eventType: document.getElementById("eventType").value,
        sensorValueNumber: Number(document.getElementById("sensorValueNumber").value || 0),
        sensorUnit: document.getElementById("sensorUnit").value.trim(),
        severity: document.getElementById("severity").value,
        component: document.getElementById("component").value.trim(),
        recommendedAction: document.getElementById("recommendedAction").value.trim(),
        status: document.getElementById("status").value
      };

      try {
        const res = await fetch("/send-telemetry-to-crm", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });

        const data = await res.json();

        if (res.ok && data.success) {
          document.getElementById("successBox").style.display = "block";
          let msg = data.message || "Success";
          if (data.telematicEventId) msg += " | Telematic Event: " + data.telematicEventId;
          if (data.caseId) msg += " | Case: " + data.caseId;
          document.getElementById("resultText").innerText = msg;
        } else {
          document.getElementById("failBox").style.display = "block";
          document.getElementById("resultText").innerText =
            (data && (data.message || JSON.stringify(data))) || "Error";
          console.log("Salesforce Error:", data);
        }
      } catch (err) {
        document.getElementById("failBox").style.display = "block";
        document.getElementById("resultText").innerText = err.message;
        console.log("Error:", err.message);
      }
    }
  </script>
</body>
</html>
