<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Claims</title>

  <style>
    :root{
      /* Lush forest palette */
      --g1: #2E6F40; /* primary forest green */
      --g2: #CFFDFC; /* mint light */
      --g3: #68BA7F; /* soft green */
      --g4: #253D2C; /* deep green */

      /* ✅ Background to WHITE (as requested) */
      --page-bg: #ffffff;

      --text: #0f172a;
      --muted: #355a45;

      --border: rgba(37, 61, 44, 0.18);
      --hover: rgba(104, 186, 127, 0.18);

      /* alternating rows: white + grey */
      --row-odd: #ffffff;
      --row-even: #f2f2f2;
    }

    body {
      font-family: "Segoe UI", Arial, sans-serif;
      background: var(--page-bg);
      margin: 18px;
      color: var(--text);
    }

    h2 {
      margin: 0 0 14px;
      font-weight: 800;
      text-align: center;
      color: var(--g4);
      letter-spacing: 0.2px;
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      table-layout: fixed;
      background: #ffffff;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 10px 24px rgba(37, 61, 44, 0.12);
    }

    th, td {
      border: 1px solid var(--border);
      padding: 12px;
      font-size: 13px;
      vertical-align: top;
      word-wrap: break-word;
      white-space: normal;
      line-height: 1.45;
    }

    th {
      background: var(--g4);
      color: #ffffff;
      font-weight: 800;
      text-align: left;
      border-color: rgba(255,255,255,0.14);
    }

    .assetCell { line-height: 1.55; }

    .muted {
      color: var(--muted);
      font-size: 12px;
    }

    th .muted {
      color: rgba(207, 253, 252, 0.88);
      font-weight: 600;
      font-size: 11px;
    }

    thead tr th:first-child,
    tbody tr td:first-child { border-left: 0; }
    thead tr th:last-child,
    tbody tr td:last-child { border-right: 0; }
    thead tr th { border-top: 0; }
    tbody tr:last-child td { border-bottom: 0; }

    tbody tr:nth-child(odd) td  { background: var(--row-odd); }
    tbody tr:nth-child(even) td { background: var(--row-even); }

    tbody tr:hover td { background: var(--hover); }

    input.amountPaid {
      width: 100%;
      padding: 8px 10px;
      border: 1px solid rgba(37, 61, 44, 0.30);
      border-radius: 8px;
      font-size: 13px;
      background: #fff;
      box-sizing: border-box;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }

    input.amountPaid:focus {
      outline: none;
      border-color: var(--g3);
      box-shadow: 0 0 0 3px rgba(104, 186, 127, 0.25);
    }

    .btnBar {
      margin-top: 16px;
      display: flex;
      gap: 10px;
      justify-content: center;
    }

    .btn {
      background: var(--g1);
      color: #fff;
      border: none;
      padding: 10px 16px;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 800;
      letter-spacing: 0.2px;
      box-shadow: 0 10px 20px rgba(37, 61, 44, 0.18);
      transition: transform 0.08s ease, filter 0.2s ease, box-shadow 0.2s ease;
    }

    .btn:hover {
      background: var(--g4);
      box-shadow: 0 12px 24px rgba(37, 61, 44, 0.22);
    }

    .btn:active {
      transform: translateY(1px);
    }

    .note { margin-top: 10px; color: #3f5f4c; font-size: 12px; text-align: center; }
  </style>
</head>

<body>
  <h2>Claims</h2>

  <% if (!claimHeader) { %>
    <p>No claim received yet. Trigger the Salesforce LWC Quick Action to send a claim.</p>
  <% } else { %>

    <table id="claimsTable">
      <thead>
        <tr>
          <th style="width: 16%;">Dealer Account </th>
          <th style="width: 14%;">Repair Order </th>
          <th style="width: 10%;">Claim No.</th>
          <th style="width: 22%;">Asset</th>
          <th style="width: 18%;">Claimed Parts and Labor<br><span class="muted">Claim Coverage names</span></th>
          <th style="width: 10%;">Total Claimed Amount</th>
          <th style="width: 10%;">Amount Paid</th>
        </tr>
      </thead>

      <tbody>
        <% if (!rows || rows.length === 0) { %>
          <tr><td colspan="7">No rows created (coverage counts may be 0).</td></tr>
        <% } else { 
             const first = rows[0];
        %>
          <!-- ✅ Single UI row only -->
          <tr>
            <td><%= claimHeader.dealerAccountName || "-" %></td>
            <td><%= claimHeader.repairOrder || "-" %></td>
            <td><%= claimHeader.claimNumber || "-" %></td>

            <!-- ✅ Asset: only Asset Registration No & VIN -->
            <td class="assetCell">
              <b>Asset Registration No:</b> <%= assetBlock?.assetRegNo || "-" %><br>
              <b>VIN No:</b> <%= assetBlock?.vin || "-" %>
            </td>

            <!-- ✅ Single cell with all Claim Coverage names -->
            <td><%= claimHeader.claimedPartsAndLabor || "-" %></td>

            <td><%= (claimHeader.totalClaimedAmount ?? first.totalClaimedAmount ?? "-") %></td>

            <!-- ✅ Single input, but submit will apply to all rows -->
            <td>
              <input
                class="amountPaid"
                type="number"
                step="0.01"
                min="0"
                data-index="0"
                value="<%= first.amountPaid == null ? '' : first.amountPaid %>"
                placeholder="Enter amount"/>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>

    <div class="btnBar">
      <button class="btn" id="submitBtn">Submit Amount Paid</button>
    </div>

    <div class="note"></div>

  <% } %>

  <script>
    const rows = <%- JSON.stringify(rows || []) %>;

    const submitBtn = document.getElementById("submitBtn");
    if (submitBtn) {
      submitBtn.addEventListener("click", async (e) => {
        e.preventDefault();

        // ✅ Single Amount Paid input -> apply to ALL rows (keeps existing backend functionality)
        const inp = document.querySelector("input.amountPaid");
        const val = inp ? inp.value : "";

        rows.forEach(r => {
          r.amountPaid = val;
        });

        try {
          const res = await fetch("/submit-claim-amounts", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ rows })
          });

          const data = await res.json().catch(() => null);

          if (res.ok) alert("✅ Amount Paid sent to Salesforce successfully!");
          else alert("❌ Error: " + (data?.message || JSON.stringify(data)));

        } catch (err) {
          alert("Network error: " + err.message);
        }
      });
    }
  </script>
</body>
</html>
