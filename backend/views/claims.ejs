<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Claims</title>

  <style>
    :root{
      /* Blue eclipse palette (from your image) */
      --c1: #272757; /* midnight indigo */
      --c2: #8686AC; /* soft lavender */
      --c3: #505081; /* slate purple */
      --c4: #0F0E47; /* deep navy */

      /* neutrals that still match the palette */
      --page-bg: #f4f5fb;      /* light background */
      --table-bg: #ffffff;     /* white */
      --border: #d7d9e8;       /* cool border */
      --row-grey: #f0f1f7;     /* grey (blue-tinted) */
      --row-white: #ffffff;    /* white */
      --hover: #e7e9f6;        /* hover tint */

      --text: #111827;
      --muted: #4b5563;
    }

    body {
      font-family: "Segoe UI", Arial, sans-serif;
      background: var(--page-bg);
      margin: 18px auto;
      padding: 18px;
      max-width: 1200px;
      color: var(--text);
    }

    h2 {
      margin: 0 0 14px;
      font-weight: 700;
      text-align: center; /* ✅ centered heading */
      color: var(--c4);
      letter-spacing: 0.2px;
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      table-layout: fixed;
      background: var(--table-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 10px 24px rgba(15, 14, 71, 0.08);
    }

    th, td {
      border: 1px solid var(--border);
      padding: 12px;
      font-size: 13px;
      vertical-align: top;
      word-wrap: break-word;
      white-space: normal;
      line-height: 1.45;
    }

    /* ✅ Header using palette */
    thead th {
      background: linear-gradient(0deg, var(--c4), var(--c1));
      color: #ffffff;
      font-weight: 800;
      text-align: left;
      border-color: rgba(255,255,255,0.14);
    }

    /* subtle header separator */
    thead th + th {
      border-left-color: rgba(255,255,255,0.12);
    }

    .muted {
      color: var(--muted);
      font-size: 12px;
    }

    /* muted inside header should be readable on dark bg */
    thead .muted{
      color: rgba(255,255,255,0.78);
      font-weight: 600;
      font-size: 11px;
    }

    /* remove double borders on outer edges (clean rounded look) */
    thead tr th:first-child,
    tbody tr td:first-child { border-left: 0; }
    thead tr th:last-child,
    tbody tr td:last-child { border-right: 0; }
    thead tr th { border-top: 0; }
    tbody tr:last-child td { border-bottom: 0; }

    /* ✅ Alternating row colors: grey + white */
    tbody tr:nth-child(odd) td  { background: var(--row-white); }
    tbody tr:nth-child(even) td { background: var(--row-grey); }

    tbody tr:hover td { background: var(--hover); }

    .assetCell { line-height: 1.55; }

    input.amountPaid {
      width: 100%;
      padding: 8px 10px;
      border: 1px solid #c7cbe0;
      border-radius: 8px;
      font-size: 13px;
      background: #ffffff;
      box-sizing: border-box;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }

    input.amountPaid:focus {
      outline: none;
      border-color: var(--c3);
      box-shadow: 0 0 0 3px rgba(134, 134, 172, 0.28); /* uses c2 glow */
    }

    /* ✅ Button centered */
    .btnBar {
      margin-top: 16px;
      display: flex;
      gap: 10px;
      justify-content: center;
    }

    /* ✅ Button using palette */
    .btn {
      background: linear-gradient(0deg, var(--c1), var(--c4));
      color: #fff;
      border: 1px solid rgba(255,255,255,0.12);
      padding: 10px 16px;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 800;
      letter-spacing: 0.2px;
      box-shadow: 0 10px 20px rgba(15, 14, 71, 0.18);
      transition: transform 0.08s ease, box-shadow 0.2s ease, filter 0.2s ease;
    }

    .btn:hover {
      filter: brightness(1.05);
      box-shadow: 0 12px 24px rgba(15, 14, 71, 0.24);
    }

    .btn:active {
      transform: translateY(1px);
    }

    .note {
      margin-top: 10px;
      color: #6b7280;
      font-size: 12px;
      text-align: center;
    }
  </style>
</head>

<body>
  <h2>Claims</h2>

  <% if (!claimHeader) { %>
    <p>No claim received yet. Trigger the Salesforce LWC Quick Action to send a claim.</p>
  <% } else { %>

    <table id="claimsTable">
      <thead>
        <tr>
          <th style="width: 16%;">Dealer Account </th>
          <th style="width: 14%;">Repair Order </th>
          <th style="width: 10%;">Claim No.</th>
          <th style="width: 22%;">Asset</th>
          <th style="width: 18%;">Claimed Parts and Labor<br><span class="muted">All product names from Claim Coverage</span></th>
          <th style="width: 10%;">Total Claimed Amount</th>
          <th style="width: 10%;">Amount Paid<br><span class="muted"></span></th>
        </tr>
      </thead>

      <tbody>
        <% if (!rows || rows.length === 0) { %>
          <tr><td colspan="7">No rows created (coverage counts may be 0).</td></tr>
        <% } else { %>
          <% rows.forEach((r, idx) => { %>
            <tr>
              <td><%= claimHeader.dealerAccountName || "-" %></td>
              <td><%= claimHeader.repairOrder || "-" %></td>
              <td><%= claimHeader.claimNumber || "-" %></td>

              <td class="assetCell">
                <b>Warranty:</b> <%= assetBlock?.warranty || "-" %><br>
                <b>Asset Registration No:</b> <%= assetBlock?.assetRegNo || "-" %><br>
                <b>VIN No:</b> <%= assetBlock?.vin || "-" %><br>
                <b>Asset Owner:</b> <%= assetBlock?.assetOwner || "-" %>
                <div class="muted" style="margin-top:6px;">(All info from Claim Item)</div>
              </td>

              <td>
                <%= r.productName || "-" %>
                <div class="muted" style="margin-top:6px;">
                  <b><%= r.coverageType %></b> • Line <%= r.lineNumber %>
                </div>
              </td>

              <td><%= (r.totalClaimedAmount ?? "-") %></td>

              <td>
                <input
                  class="amountPaid"
                  type="number"
                  step="0.01"
                  min="0"
                  data-index="<%= idx %>"
                  value="<%= r.amountPaid == null ? '' : r.amountPaid %>"
                  placeholder="Enter amount"/>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>

    <div class="btnBar">
      <button class="btn" id="submitBtn">Submit Amount Paid</button>
    </div>

    <div class="note">
      
    </div>

  <% } %>

  <script>
    const rows = <%- JSON.stringify(rows || []) %>;

    const submitBtn = document.getElementById("submitBtn");
    if (submitBtn) {
      submitBtn.addEventListener("click", async (e) => {
        e.preventDefault();

        // Read Amount Paid values back
        document.querySelectorAll("input.amountPaid").forEach(inp => {
          const idx = Number(inp.dataset.index);
          if (!Number.isNaN(idx) && rows[idx]) {
            rows[idx].amountPaid = inp.value;
          }
        });

        try {
          const res = await fetch("/submit-claim-amounts", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ rows })
          });

          const data = await res.json().catch(() => null);

          if (res.ok) alert("✅ Amount Paid sent to Salesforce successfully!");
          else alert("❌ Error: " + (data?.message || JSON.stringify(data)));

        } catch (err) {
          alert("Network error: " + err.message);
        }
      });
    }
  </script>
</body>
</html>
