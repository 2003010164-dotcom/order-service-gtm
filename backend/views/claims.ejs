<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Claims</title>

  <style>
    :root{
      /* Lush forest palette */
      --g1: #2E6F40;
      --g2: #CFFDFC;
      --g3: #68BA7F;
      --g4: #253D2C;

      /* Background WHITE */
      --page-bg: #ffffff;

      --text: #0f172a;
      --muted: #355a45;

      --border: rgba(37, 61, 44, 0.18);
      --hover: rgba(104, 186, 127, 0.18);

      --row-odd: #ffffff;
      --row-even: #f2f2f2;
    }

    body {
      font-family: "Segoe UI", Arial, sans-serif;
      background: var(--page-bg);
      margin: 18px;
      color: var(--text);
    }

    h2 {
      margin: 0 0 14px;
      font-weight: 800;
      text-align: center;
      color: var(--g4);
      letter-spacing: 0.2px;
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      table-layout: fixed;
      background: #ffffff;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 10px 24px rgba(37, 61, 44, 0.12);
    }

    th, td {
      border: 1px solid var(--border);
      padding: 12px;
      font-size: 13px;
      vertical-align: top;
      word-wrap: break-word;
      white-space: normal;
      line-height: 1.45;
    }

    th {
      background: var(--g4);
      color: #ffffff;
      font-weight: 800;
      text-align: left;
      border-color: rgba(255,255,255,0.14);
    }

    .assetCell { line-height: 1.55; }

    .muted {
      color: var(--muted);
      font-size: 12px;
    }

    th .muted {
      color: rgba(207, 253, 252, 0.88);
      font-weight: 600;
      font-size: 11px;
    }

    thead tr th:first-child,
    tbody tr td:first-child { border-left: 0; }
    thead tr th:last-child,
    tbody tr td:last-child { border-right: 0; }
    thead tr th { border-top: 0; }
    tbody tr:last-child td { border-bottom: 0; }

    tbody tr:nth-child(odd) td  { background: var(--row-odd); }
    tbody tr:nth-child(even) td { background: var(--row-even); }

    tbody tr:hover td { background: var(--hover); }

    input.amountPaid {
      width: 100%;
      padding: 8px 10px;
      border: 1px solid rgba(37, 61, 44, 0.30);
      border-radius: 8px;
      font-size: 13px;
      background: #fff;
      box-sizing: border-box;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }

    input.amountPaid:focus {
      outline: none;
      border-color: var(--g3);
      box-shadow: 0 0 0 3px rgba(104, 186, 127, 0.25);
    }

    .btnBar {
      margin-top: 16px;
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn {
      background: var(--g1);
      color: #fff;
      border: none;
      padding: 10px 16px;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 800;
      letter-spacing: 0.2px;
      box-shadow: 0 10px 20px rgba(37, 61, 44, 0.18);
      transition: transform 0.08s ease, filter 0.2s ease, box-shadow 0.2s ease;
    }

    .btn:hover {
      background: var(--g4);
      box-shadow: 0 12px 24px rgba(37, 61, 44, 0.22);
    }

    .btn:active {
      transform: translateY(1px);
    }

    /* extra button colors */
    .btn-approve { background: #2E6F40; }
    .btn-reject  { background: #B91C1C; }
    .btn-close   { background: #253D2C; }

    .note { margin-top: 10px; color: #3f5f4c; font-size: 12px; text-align: center; }

    /* Show coverages on next lines */
    .coverageCell { white-space: pre-line; }
  </style>
</head>

<body>
  <h2>Claims</h2>

  <% if (!claimHeader) { %>
    <p>No claim received yet. Trigger the Salesforce LWC Quick Action to send a claim.</p>
  <% } else { %>

    <table id="claimsTable">
      <thead>
        <tr>
          <th style="width: 16%;">Dealer Account</th>
          <th style="width: 14%;">Repair Order</th>
          <th style="width: 10%;">Claim No.</th>
          <th style="width: 22%;">Asset</th>
          <th style="width: 18%;">Claimed Parts and Labor<br><span class="muted">Claim Coverage names</span></th>
          <th style="width: 10%;">Total Claimed Amount(SEK)</th>
          <th style="width: 10%;">Amount Paid(SEK)</th>
        </tr>
      </thead>

      <tbody>
        <% if (!rows || rows.length === 0) { %>
          <tr><td colspan="7">No rows created (coverage counts may be 0).</td></tr>
        <% } else {
             const first = rows[0];

             const rawCoverage = (claimHeader && claimHeader.claimedPartsAndLabor)
               ? String(claimHeader.claimedPartsAndLabor)
               : "";
             const coverageDisplay = rawCoverage ? rawCoverage.replace(/,\s*/g, "\n") : "-";
        %>

          <tr>
            <td><%= claimHeader.dealerAccountName || "-" %></td>
            <td><%= claimHeader.repairOrder || "-" %></td>
            <td><%= claimHeader.claimNumber || "-" %></td>

            <td class="assetCell">
              <b>Asset Registration No:</b> <%= assetBlock?.assetRegNo || "-" %><br>
              <b>VIN No:</b> <%= assetBlock?.vin || "-" %>
            </td>

            <td class="coverageCell"><%= coverageDisplay %></td>

            <td><%= (claimHeader.totalClaimedAmount ?? first.totalClaimedAmount ?? "-") %></td>

            <td>
              <input
                class="amountPaid"
                type="number"
                step="0.01"
                min="0"
                data-index="0"
                value=""
                placeholder="Enter amount"/>
            </td>
          </tr>

        <% } %>
      </tbody>
    </table>

    <!-- ✅ Buttons -->
    <div class="btnBar">
      <button class="btn" id="submitBtn">Submit Amount Paid</button>
      <button class="btn btn-approve" id="approveBtn">Approved</button>
      <button class="btn btn-reject" id="rejectBtn">Rejected</button>
      <button class="btn btn-close" id="closeBtn">Closed</button>
    </div>

    <div class="note"></div>

  <% } %>

  <script>
    // existing rows payload (unchanged)
    const rows = <%- JSON.stringify(rows || []) %>;

    // ✅ claim context values for status mapping
    const CLAIM_ID = "<%= (claimHeader && claimHeader.claimId) ? claimHeader.claimId : '' %>";

    // TOTAL = Claim Total Claimed Amount (fallback to first row)
    const TOTAL = (() => {
      const v = "<%= (claimHeader && claimHeader.totalClaimedAmount != null) ? claimHeader.totalClaimedAmount : '' %>";
      const asNum = Number(v);
      if (!Number.isNaN(asNum) && v !== '') return asNum;
      const fallback = rows && rows[0] ? Number(rows[0].totalClaimedAmount) : 0;
      return Number.isNaN(fallback) ? 0 : fallback;
    })();

    // ----------------------------
    // ✅ Helper: read PAID from input
    // ----------------------------
    function readPaid() {
      const inp = document.querySelector("input.amountPaid");
      const val = inp ? inp.value : "";
      const n = (val === "" || val == null) ? 0 : Number(val);
      return Number.isNaN(n) ? 0 : n;
    }

    // ----------------------------
    // ✅ Helper: distribute total across rows (same logic you use in Submit)
    // ----------------------------
    function distributeAcrossRows(total) {
      if (total == null || Number.isNaN(total)) {
        rows.forEach(r => { r.amountPaid = ""; });
        return;
      }

      const n = rows.length || 1;

      const per = Math.floor((total / n) * 100) / 100;
      let used = 0;

      rows.forEach((r, i) => {
        if (i < n - 1) {
          r.amountPaid = per.toFixed(2);
          used += per;
        } else {
          const last = Math.round((total - used) * 100) / 100;
          r.amountPaid = last.toFixed(2);
        }
      });
    }

    // ----------------------------
    // ✅ Helper: submit payment to Salesforce (reuses existing endpoint)
    // ----------------------------
    async function submitPayment(total) {
      distributeAcrossRows(total);

      const res = await fetch("/submit-claim-amounts", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ rows })
      });

      const data = await res.json().catch(() => null);
      if (!res.ok) throw new Error(data?.message || JSON.stringify(data) || "Payment submit failed");
      return data;
    }

    // ----------------------------
    // ✅ Helper: update claim status via Node route
    // ----------------------------
    async function updateClaimStatus(status) {
      if (!CLAIM_ID) throw new Error("ClaimId not found in page.");

      const res = await fetch("/update-claim-status", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ claimId: CLAIM_ID, status })
      });

      const data = await res.json().catch(() => null);
      if (!res.ok) throw new Error(data?.message || JSON.stringify(data) || "Status update failed");
      return data;
    }

    // ----------------------------
    // ✅ Status mapping (exact requirement)
    // ----------------------------
    function statusForApprove(paid, total) {
      if (paid <= 0) return "Approved";
      if (paid > 0 && paid < total) return "Pending";
      return "Paid-in Full"; // paid >= total
    }

    function statusForClose(paid, total) {
      if (paid >= total) return "Closed";
      if (paid > 0 && paid < total) return "Compromised/Settled";
      return "Closed"; // paid == 0 -> Closed but payment not completed
    }

    // ==========================================================
    // ✅ EXISTING Submit Amount Paid button logic (UNCHANGED)
    // ==========================================================
    const submitBtn = document.getElementById("submitBtn");
    if (submitBtn) {
      submitBtn.addEventListener("click", async (e) => {
        e.preventDefault();

        // ✅ Treat input as TOTAL claim paid amount
        const inp = document.querySelector("input.amountPaid");
        const val = inp ? inp.value : "";

        const total = (val === "" || val == null) ? null : Number(val);

        if (total == null || Number.isNaN(total)) {
          rows.forEach(r => { r.amountPaid = ""; });
        } else {
          const n = rows.length || 1;
          const per = Math.floor((total / n) * 100) / 100;
          let used = 0;

          rows.forEach((r, i) => {
            if (i < n - 1) {
              r.amountPaid = per.toFixed(2);
              used += per;
            } else {
              const last = Math.round((total - used) * 100) / 100;
              r.amountPaid = last.toFixed(2);
            }
          });
        }

        try {
          const res = await fetch("/submit-claim-amounts", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ rows })
          });

          const data = await res.json().catch(() => null);

          if (res.ok) alert("✅ Amount Paid sent to Salesforce successfully!");
          else alert("❌ Error: " + (data?.message || JSON.stringify(data)));

        } catch (err) {
          alert("Network error: " + err.message);
        }
      });
    }

    // ==========================================================
    // ✅ NEW Buttons: Approved / Rejected / Closed
    // (No changes to existing submit functionality)
    // ==========================================================
    const approveBtn = document.getElementById("approveBtn");
    const rejectBtn  = document.getElementById("rejectBtn");
    const closeBtn   = document.getElementById("closeBtn");

    if (approveBtn) {
      approveBtn.addEventListener("click", async (e) => {
        e.preventDefault();
        try {
          const paid = readPaid();

          // payment should be stored too
          await submitPayment(paid);

          const status = statusForApprove(paid, TOTAL);
          await updateClaimStatus(status);

          alert("✅ Approved flow done. Status set to: " + status);
        } catch (err) {
          alert("❌ " + err.message);
        }
      });
    }

    if (rejectBtn) {
      rejectBtn.addEventListener("click", async (e) => {
        e.preventDefault();
        try {
          const status = "Rejected";
          await updateClaimStatus(status);
          alert("✅ Rejected. Status set to: " + status);
        } catch (err) {
          alert("❌ " + err.message);
        }
      });
    }

    if (closeBtn) {
      closeBtn.addEventListener("click", async (e) => {
        e.preventDefault();
        try {
          const paid = readPaid();

          // payment should be stored too
          await submitPayment(paid);

          const status = statusForClose(paid, TOTAL);
          await updateClaimStatus(status);

          alert("✅ Closed flow done. Status set to: " + status);
        } catch (err) {
          alert("❌ " + err.message);
        }
      });
    }
  </script>
</body>
</html>
