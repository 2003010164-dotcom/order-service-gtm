<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login | Order Manager App</title>
  <style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Poppins", sans-serif;
  }

  body {
    height: 100vh;
    display: flex;
    background: linear-gradient(120deg, #0B2E33, #4F7C82);
  }

  .left-panel {
    flex: 1;
    color: #B8E3E9;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    padding: 40px;
  }

  .left-panel h1 {
    font-size: 2.8rem;
    margin-bottom: 10px;
    letter-spacing: 1px;
  }

  .left-panel p {
    font-size: 1.1rem;
    opacity: 0.9;
  }

  .right-panel {
    flex: 1;
    background-color: #B8E3E9;
    display: flex;
    justify-content: center;
    align-items: center;
    border-top-left-radius: 40px;
    border-bottom-left-radius: 40px;
    box-shadow: -4px 0 15px rgba(11, 46, 51, 0.18);
  }

  .login-box {
    width: 80%;
    max-width: 350px;
  }

  .login-box h2 {
    text-align: center;
    margin-bottom: 20px;
    color: #0B2E33;
  }

  form {
    display: flex;
    flex-direction: column;
  }

  input {
    padding: 12px 15px;
    margin-bottom: 15px;
    border: 1px solid rgba(11, 46, 51, 0.25);
    border-radius: 8px;
    font-size: 15px;
    background: #B8E3E9;
    color: #0B2E33;
  }

  input:focus {
    outline: none;
    border-color: #4F7C82;
    box-shadow: 0 0 0 3px rgba(79, 124, 130, 0.18);
  }

  button {
    background-color: #4F7C82;
    color: #B8E3E9;
    padding: 12px;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    cursor: pointer;
    transition: 0.3s;
  }

  button:hover {
    background-color: #0B2E33;
  }

  .extra-links {
    text-align: center;
    margin-top: 10px;
    color: #0B2E33;
  }

  .extra-links a {
    color: #0B2E33;
    text-decoration: none;
    font-weight: 600;
  }

  .extra-links a:hover {
    text-decoration: underline;
  }
</style>
</head>

<body>
  <div class="left-panel">
    <h1>Welcome</h1>

  </div>

  <div class="right-panel">
    <div class="login-box">
      <h2>Login</h2>
      <form action="/login" method="POST">
        <input type="email" name="email" placeholder="Enter your email" required />
        <input type="password" name="password" placeholder="Enter your password" required />
        <button type="submit">Login</button>
      </form>

      <div class="extra-links">
        <p>Click Login to Proceed</p>
      </div>
    </div>
  </div>
</body>
</html>
