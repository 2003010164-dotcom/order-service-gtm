<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Welcome</title>

  <!-- Google Font for Gen Z vibe -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

  <style>
  body {
    font-family: "Poppins", "Segoe UI", Arial, sans-serif;
    background: linear-gradient(120deg, #0B2E33, #4F7C82);
    margin: 0;
    color: #B8E3E9;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 60px 30px;
  }

  h1 {
    font-size: 2.8rem;
    font-weight: 700;
    margin-bottom: 12px;
    letter-spacing: 0.5px;
    color: #B8E3E9;
  }

  .subtitle {
    font-size: 1.1rem;
    max-width: 760px;
    line-height: 1.7;
    opacity: 0.9;
    color: rgba(184, 227, 233, 0.88);
  }

  .hero-image {
    margin-top: 30px;
    max-width: 520px;
    width: 100%;
    filter: drop-shadow(0 20px 40px rgba(11,46,51,0.45));
    border-radius: 18px;
  }

  .cards {
    display: flex;
    gap: 30px;
    margin-top: 55px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .card {
    background: rgba(184, 227, 233, 0.10);
    backdrop-filter: blur(12px);
    padding: 28px;
    border-radius: 18px;
    width: 300px;
    box-shadow: 0 12px 35px rgba(11, 46, 51, 0.28);
    transition: transform 0.35s ease, box-shadow 0.35s ease;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(184, 227, 233, 0.14);
  }

  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent, rgba(184,227,233,0.10), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 20px 45px rgba(11, 46, 51, 0.42);
  }

  .card:hover::before {
    opacity: 1;
  }

  .card img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 14px;
    margin-bottom: 18px;
  }

  .card h3 {
    margin-bottom: 8px;
    font-weight: 600;
    color: #B8E3E9;
  }

  .card p {
    font-size: 0.95rem;
    color: rgba(184, 227, 233, 0.88);
    line-height: 1.6;
  }

  .emoji {
    font-size: 1.3rem;
    margin-right: 6px;
  }
</style>
</head>

<body>

<%- include('navbar') %>

<div class="content">

  <h1>Manufacturer Order Management System</h1>

  <p class="subtitle">
    This portal enables manufacturers to seamlessly manage Vehicle and Parts
    orders received from dealers. Track order lifecycle, update fulfillment
    status, and sync data in real-time with Salesforce.
  </p>

  

  <div class="cards">

    <div class="card">
      <img
        src="https://images.unsplash.com/photo-1619642761034-765dfdf7c58e"
        alt="Vehicle Orders"
      />
      <h3><span class="emoji">🚗</span>Vehicle Orders</h3>
      <p>
        Manage vehicle manufacturing orders, track production stages,
        and confirm delivery to dealers.
      </p>
    </div>

    <div class="card">
      <img
        src="https://images.unsplash.com/photo-1581092160607-ee22621dd758"
        alt="Parts Orders"
      />
      <h3><span class="emoji">⚙️</span>Parts Orders</h3>
      <p>
        Handle spare parts orders, update inventory availability,
        and ensure timely fulfillment.
      </p>
    </div>

  </div>
</div>

</body>
</html>
