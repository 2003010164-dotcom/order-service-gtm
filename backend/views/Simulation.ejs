<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Driver View Simulation</title>

  <style>
    :root{
      --text: rgba(255,255,255,.92);
      --muted: rgba(255,255,255,.70);
      --shadow: 0 20px 60px rgba(0,0,0,.55);
      --shadow2: 0 10px 28px rgba(0,0,0,.45);
      --dash: rgba(8,12,18,.92);
      --dash2: rgba(10,16,26,.96);
      --accent: #46a8be;
      --good: #39d98a;
      --warn: #ffb020;
      --danger: #ff4d4d;
      --stroke: rgba(255,255,255,.14);
    }

    *{ box-sizing: border-box; }
    html, body { margin: 0; height: 100%; font-family: Arial, sans-serif; background: #05070b; }

    /* Fullscreen driver view */
    .frame{
      position: relative;
      height: 100vh;
      overflow: hidden;
      background: #05070b;
    }

    /* Outside view background (CSS fallback night scene) */
    .outside{
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at 50% 25%, rgba(255,255,255,.10), transparent 45%),
        radial-gradient(circle at 18% 18%, rgba(70,168,190,.18), transparent 35%),
        radial-gradient(circle at 82% 22%, rgba(255,176,32,.14), transparent 35%),
        linear-gradient(180deg, #0f2a33 0%, #12344f 30%, #0a1b2d 60%, #02040a 100%);
      background-size: cover;
      background-position: center;
    }

    /* OPTIONAL: if you place a real driver-view image at /public/img/driver_view.jpg */
    .outside.hasPhoto{
      background-image: url("/img/driver_view.jpg");
      background-size: cover;
      background-position: center;
    }

    /* Windshield glass tint */
    .glass{
      position:absolute;
      inset:0;
      background: linear-gradient(180deg, rgba(0,0,0,.10) 0%, rgba(0,0,0,.30) 55%, rgba(0,0,0,.78) 100%);
      pointer-events:none;
    }

    /* City bokeh lights (pure CSS) */
    .bokeh{
      position:absolute;
      inset:-10%;
      pointer-events:none;
      opacity:.8;
      filter: blur(8px);
    }
    .bokeh::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at 18% 35%, rgba(255,180,70,.55) 0 10px, transparent 12px),
        radial-gradient(circle at 26% 44%, rgba(255,80,80,.45) 0 8px, transparent 10px),
        radial-gradient(circle at 46% 33%, rgba(70,168,190,.55) 0 10px, transparent 12px),
        radial-gradient(circle at 62% 42%, rgba(255,255,255,.35) 0 8px, transparent 10px),
        radial-gradient(circle at 80% 34%, rgba(255,176,32,.55) 0 12px, transparent 14px),
        radial-gradient(circle at 88% 48%, rgba(255,80,80,.45) 0 9px, transparent 11px),
        radial-gradient(circle at 12% 60%, rgba(255,255,255,.25) 0 8px, transparent 10px),
        radial-gradient(circle at 52% 58%, rgba(70,168,190,.45) 0 10px, transparent 12px),
        radial-gradient(circle at 72% 62%, rgba(255,180,70,.45) 0 12px, transparent 14px);
      transform: translateY(0);
      animation: drift 10s linear infinite;
    }
    @keyframes drift{
      0%{ transform: translateY(0); }
      100%{ transform: translateY(40px); }
    }

    /* Top right quick links */
    .links{
      position:absolute;
      top: 14px;
      right: 14px;
      display:flex;
      gap:10px;
      z-index: 7;
    }
    .links a{
      color: var(--text);
      text-decoration:none;
      font-weight: 900;
      font-size: 12px;
      padding: 10px 12px;
      border-radius: 999px;
      background: rgba(0,0,0,.35);
      border: 1px solid rgba(255,255,255,.12);
      backdrop-filter: blur(8px);
    }
    .links a:hover{ background: rgba(0,0,0,.55); }

    /* Dashboard base */
    .dash{
      position:absolute;
      left:50%;
      bottom:-10%;
      transform: translateX(-50%);
      width: min(1200px, 96vw);
      height: min(520px, 68vh);
      background:
        radial-gradient(circle at 50% 0%, rgba(255,255,255,.05), transparent 60%),
        linear-gradient(180deg, var(--dash) 0%, var(--dash2) 70%, rgba(0,0,0,.98) 100%);
      border-radius: 46px 46px 110px 110px;
      border: 1px solid rgba(255,255,255,.10);
      box-shadow: var(--shadow);
      overflow: hidden;
      z-index: 4;
    }

    .dash::before{
      content:"";
      position:absolute;
      left: 7%;
      right: 7%;
      top: 6%;
      height: 20%;
      border-radius: 30px;
      background: linear-gradient(180deg, rgba(255,255,255,.06), transparent);
      border: 1px solid rgba(255,255,255,.08);
      opacity: .85;
    }

    /* Instrument cluster */
    .cluster{
      position:absolute;
      left:50%;
      top: 14%;
      transform: translateX(-50%);
      width: min(860px, 92%);
      height: 280px;
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(5,7,12,.92), rgba(8,12,22,.96));
      border: 1px solid rgba(255,255,255,.12);
      box-shadow: var(--shadow2);
      display:grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap:14px;
      padding:14px;
    }

    .gauge{
      border-radius: 22px;
      background:
        radial-gradient(circle at 50% 35%, rgba(255,255,255,.08), transparent 60%),
        linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
      border: 1px solid rgba(255,255,255,.10);
      position:relative;
      padding: 12px;
      overflow:hidden;
    }

    .gTitle{
      font-size: 12px;
      color: var(--muted);
      font-weight: 900;
      letter-spacing: .6px;
      text-transform: uppercase;
    }
    .gValue{
      margin-top: 12px;
      font-size: 40px;
      font-weight: 900;
      color: var(--text);
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .gUnit{
      margin-top: 6px;
      font-size: 12px;
      font-weight: 900;
      color: rgba(255,255,255,.62);
      letter-spacing: .3px;
    }

    /* Mini dial/needle for each gauge */
    .dial{
      position:absolute;
      right: 12px;
      bottom: 12px;
      width: 110px;
      height: 110px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.12);
      background: radial-gradient(circle at 50% 50%, rgba(255,255,255,.05), rgba(0,0,0,.55));
      display:grid;
      place-items:center;
    }
    .dial .ring{
      width: 88px;
      height: 88px;
      border-radius: 999px;
      border: 1px dashed rgba(255,255,255,.14);
      position:relative;
    }
    .dial .needle{
      position:absolute;
      left:50%;
      top:50%;
      width: 42px;
      height: 3px;
      background: var(--accent);
      transform-origin: 0% 50%;
      transform: translateY(-50%) rotate(-55deg);
      border-radius: 999px;
      box-shadow: 0 0 18px rgba(70,168,190,.45);
    }
    .dial .cap{
      position:absolute;
      left:50%;
      top:50%;
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: rgba(255,255,255,.85);
      transform: translate(-50%,-50%);
      box-shadow: 0 0 0 4px rgba(255,255,255,.10);
    }

    /* ===== Time gauge with tablet next to it (inside same tile) ===== */
    .time-gauge{ overflow: visible; }

    .timeRow{
      display:flex;
      align-items:flex-start;
      gap:12px;
      margin-top: 8px;
    }

    .timeInfo{
      min-width: 96px;
    }

    /* Tablet container */
    .miniTablet{
      flex: 1;
      height: 150px;
      border-radius: 14px;
      background: linear-gradient(180deg, rgba(255,255,255,.07), rgba(0,0,0,.35));
      border: 1px solid rgba(255,255,255,.14);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,.08);
      padding: 8px;
      display:flex;
      flex-direction:column;
      gap:6px;
    }

    /* Tablet top bar */
    .tabletHeader{
      font-size: 10px;
      font-weight: 900;
      letter-spacing: .4px;
      color: rgba(255,255,255,.88);
      background: rgba(0,0,0,.35);
      padding: 4px 8px;
      border-radius: 8px;
      border: 1px solid rgba(255,255,255,.10);
    }

    /* Map view (abstract “Google maps” feel – original, not copied) */
    .tabletMap{
      position: relative;
      flex: 1;
      border-radius: 10px;
      background:
        radial-gradient(circle at 25% 70%, rgba(57,217,138,.22) 0 40px, transparent 42px),
        radial-gradient(circle at 78% 68%, rgba(57,217,138,.18) 0 34px, transparent 36px),
        linear-gradient(120deg, rgba(255,255,255,.06) 0 8px, transparent 8px 100%),
        linear-gradient(30deg, rgba(255,255,255,.06) 0 10px, transparent 10px 100%),
        linear-gradient(180deg, rgba(12,18,28,.92), rgba(6,10,16,.92));
      overflow:hidden;
      border: 1px solid rgba(255,255,255,.10);
    }

    .tabletMap .route{
      position: absolute;
      left: 56%;
      top: 8%;
      width: 4px;
      height: 84%;
      background: linear-gradient(180deg, rgba(70,168,190,0), rgba(70,168,190,.92), rgba(70,168,190,0));
      border-radius: 999px;
      transform: rotate(10deg);
      box-shadow: 0 0 14px rgba(70,168,190,.25);
    }

    .tabletMap .pin{
      position: absolute;
      left: 60%;
      top: 48%;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: rgba(255,77,77,.95);
      box-shadow: 0 0 0 5px rgba(255,77,77,.18);
    }

    /* Tablet bottom line (display-only sensor value) */
    .tabletInput{
      display:flex;
      align-items:center;
      gap:8px;
    }

    .tabletInput .lbl{
      font-size: 10px;
      font-weight: 900;
      letter-spacing: .5px;
      color: rgba(255,255,255,.70);
      text-transform: uppercase;
      white-space: nowrap;
    }

    .tabletValue{
      flex: 1;
      height: 32px;
      border-radius: 8px;
      border: 1px solid rgba(255,255,255,.18);
      background: rgba(0,0,0,.45);
      color: rgba(255,255,255,.92);
      font-size: 16px;
      font-weight: 900;
      display:flex;
      align-items:center;
      justify-content:center;
      gap:6px;
      font-variant-numeric: tabular-nums;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
    }

    .tabletInput span{
      font-size: 12px;
      font-weight: 900;
      color: rgba(255,255,255,.75);
      letter-spacing: .3px;
      white-space: nowrap;
    }

    /* ✅ Manual sensor input box (added back) */
    .sensorBox{
      position:absolute;
      left:50%;
      bottom: 18%;
      transform: translateX(-50%);
      width: 180px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.02));
      border: 1px solid rgba(255,255,255,.14);
      box-shadow: var(--shadow2);
      display:flex;
      flex-direction:column;
      justify-content:center;
      align-items:center;
      gap: 8px;
      padding: 14px;
      z-index: 8;
      pointer-events:auto; /* allow typing */
    }

    .sensorBox .lbl{
      font-size: 11px;
      color: var(--muted);
      font-weight: 900;
      letter-spacing: .7px;
      text-transform: uppercase;
      text-align:center;
      line-height:1.2;
    }

    .sensorBox input{
      width: 100%;
      height: 52px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,.18);
      background: rgba(0,0,0,.40);
      color: var(--text);
      font-size: 22px;
      font-weight: 900;
      text-align:center;
      outline:none;
      font-variant-numeric: tabular-nums;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
    }

    .sensorBox .unit{
      font-size: 12px;
      font-weight: 900;
      color: rgba(255,255,255,.75);
      letter-spacing: .4px;
    }

    .sensorBox .hint{
      font-size: 11px;
      color: rgba(255,255,255,.55);
      text-align:center;
      line-height:1.2;
    }

    /* Steering wheel */
    .wheelWrap{
      position:absolute;
      left:50%;
      bottom:-6%;
      transform: translateX(-50%);
      width: min(620px, 96vw);
      height: min(500px, 60vh);
      z-index: 9;
      pointer-events:none;
    }
    .wheel{
      position:absolute;
      left:50%;
      bottom:0;
      transform: translateX(-50%);
      width: 380px;
      height: 380px;
      border-radius: 999px;
      border: 18px solid rgba(0,0,0,.65);
      background: radial-gradient(circle at 50% 45%, rgba(255,255,255,.06), transparent 55%);
      box-shadow: 0 18px 50px rgba(0,0,0,.60);
    }
    .wheel::before{
      content:"";
      position:absolute;
      inset: 24px;
      border-radius: 999px;
      border: 2px solid rgba(255,255,255,.08);
    }
    .hub{
      position:absolute;
      left:50%;
      top:50%;
      transform: translate(-50%,-50%);
      width: 125px;
      height: 125px;
      border-radius: 26px;
      background: linear-gradient(180deg, rgba(255,255,255,.05), rgba(0,0,0,.55));
      border: 1px solid rgba(255,255,255,.12);
      display:grid;
      place-items:center;
      color: rgba(255,255,255,.72);
      font-weight: 900;
      letter-spacing: .6px;
      font-size: 12px;
    }
    .spoke{
      position:absolute;
      left:50%;
      top:50%;
      width: 150px;
      height: 18px;
      background: rgba(0,0,0,.55);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 999px;
      transform-origin: 0% 50%;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
    }
    .spoke.s1{ transform: translate(-14px,-50%) rotate(-25deg); }
    .spoke.s2{ transform: translate(-14px,-50%) rotate(25deg); }
    .spoke.s3{ transform: translate(-14px,-50%) rotate(90deg); width: 130px; }

    /* HUD at bottom */
    .hud{
      position:absolute;
      left:50%;
      bottom: 10px;
      transform: translateX(-50%);
      width: min(980px, 95vw);
      display:flex;
      justify-content:space-between;
      gap: 10px;
      padding: 10px 14px;
      border-radius: 14px;
      background: rgba(0,0,0,.35);
      border: 1px solid rgba(255,255,255,.10);
      color: rgba(255,255,255,.82);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: .2px;
      backdrop-filter: blur(8px);
      z-index: 10;
      flex-wrap: wrap;
    }
    .hud span{ color: rgba(255,255,255,.60); font-weight: 900; }

    .badgeStatus{
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.06);
      font-weight: 900;
      white-space:nowrap;
    }
    .badgeStatus.good{ color: var(--good); }
    .badgeStatus.warn{ color: var(--warn); }
    .badgeStatus.danger{ color: var(--danger); }

    @media (max-width: 920px){
      .cluster{ grid-template-columns: 1fr; height:auto; }
      .wheel{ width: 330px; height: 330px; border-width: 16px; }

      .timeRow{
        flex-direction: column;
      }
      .timeInfo{ min-width: unset; }
      .miniTablet{ height: 170px; }

      .sensorBox{
        bottom: 22%;
        width: 170px;
      }
    }
  </style>
</head>

<body>
  <div class="frame">
    <div class="outside hasPhoto"></div>
    <div class="bokeh"></div>
    <div class="glass"></div>

    <div class="links">
      <a href="/telemetry">Telematics Page</a>
      <a href="/api/sim/state" target="_blank">API State</a>
    </div>

    <!-- Dashboard -->
    <div class="dash">
      <div class="cluster">
        <!-- Speed -->
        <div class="gauge">
          <div class="gTitle">Speed</div>
          <div class="gValue"><span id="speedVal">42</span></div>
          <div class="gUnit">km/h</div>
          <div class="dial">
            <div class="ring">
              <div class="needle" id="speedNeedle"></div>
              <div class="cap"></div>
            </div>
          </div>
        </div>

        <!-- Engine Temp -->
        <div class="gauge">
          <div class="gTitle">Engine Temp</div>
          <div class="gValue"><span id="tempVal">25</span></div>
          <div class="gUnit">°C</div>
          <div class="dial">
            <div class="ring">
              <div class="needle" id="tempNeedle"></div>
              <div class="cap"></div>
            </div>
          </div>
        </div>

        <!-- ✅ Right: Time + Tablet next to it -->
        <div class="gauge time-gauge">
          <div class="gTitle">Time</div>

          <div class="timeRow">
            <div class="timeInfo">
              <div class="gValue"><span>2:18</span></div>
              <div class="gUnit">AM</div>
            </div>

            <!-- Tablet (Google map nav + Sensor Value display) -->
            <div class="miniTablet">
              <div class="tabletHeader">Google Maps • Navigation</div>

              <div class="tabletMap">
                <div class="route"></div>
                <div class="pin"></div>
              </div>

              <div class="tabletInput">
                <div class="lbl">Sensor Value</div>
                <div class="tabletValue">
                  <span id="tabletSensorVal">25</span>
                  <span>°C</span>
                </div>
              </div>
            </div>
          </div>

          <div class="dial">
            <div class="ring">
              <div class="needle" style="transform: translateY(-50%) rotate(-10deg); background: rgba(255,255,255,.35); box-shadow:none;"></div>
              <div class="cap"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- ✅ Manual input box added back -->
      <div class="sensorBox">
        <div class="lbl">Sensor Value</div>
        <input id="tempInput" type="number" min="0" max="120" value="25" />
        <div class="unit">°C</div>
        <div class="hint">Type 31+ to exceed threshold</div>
      </div>
    </div>

    <!-- Steering wheel -->
    <div class="wheelWrap">
      <div class="wheel">
        <div class="spoke s1"></div>
        <div class="spoke s2"></div>
        <div class="spoke s3"></div>

        <!-- ✅ removed STEERING text -->
        <div class="hub"></div>
      </div>
    </div>

    <!-- HUD -->
    <div class="hud">
      <div>Streaming Event: <span>EngineTempHigh</span> | Unit: <span>C</span></div>
      <div>Auto-Send: <span>Handled by /telemetry</span></div>
      <div class="badgeStatus" id="statusBadge">Waiting…</div>
    </div>
  </div>

  <script>
    // This simulation page only updates Node state at /api/sim/state.
    // Your telematics page can poll /api/sim/state and auto-send to Salesforce.

    const tempInput = document.getElementById("tempInput");
    const tempVal = document.getElementById("tempVal");
    const speedVal = document.getElementById("speedVal");
    const tempNeedle = document.getElementById("tempNeedle");
    const speedNeedle = document.getElementById("speedNeedle");
    const statusBadge = document.getElementById("statusBadge");

    // ✅ mirror value to tablet display (added)
    const tabletSensorVal = document.getElementById("tabletSensorVal");

    let speed = 42;

    function setBadge(text, kind){
      statusBadge.textContent = text;
      statusBadge.classList.remove("good","warn","danger");
      if(kind) statusBadge.classList.add(kind);
    }

    function rotateNeedle(needleEl, value, min, max){
      const v = Math.max(min, Math.min(max, value));
      const ratio = (v - min) / (max - min);
      const angle = -60 + ratio * 120; // -60..+60
      needleEl.style.transform = `translateY(-50%) rotate(${angle}deg)`;
    }

    async function postSimState(engineTemp, speed){
      const payload = { engineTemp, speed, at: new Date().toISOString() };
      const res = await fetch("/api/sim/state", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (!res.ok || !data.ok){
        throw new Error(data.message || "Failed to post sim state");
      }
      return data;
    }

    function render(){
      const temp = Number(tempInput.value || 0);

      tempVal.textContent = temp;
      speedVal.textContent = Math.round(speed);

      rotateNeedle(tempNeedle, temp, 0, 120);
      rotateNeedle(speedNeedle, speed, 0, 160);

      // ✅ update tablet display (added)
      if (tabletSensorVal) tabletSensorVal.textContent = String(temp);

      if (temp > 30){
        setBadge("Threshold exceeded (>30) — telematics will auto-send", "danger");
      } else {
        setBadge("Normal — monitoring", "good");
      }
    }

    // Debounce typing to avoid spamming server
    let timer = null;
    function onChange(){
      render();
      clearTimeout(timer);
      timer = setTimeout(async () => {
        try{
          const temp = Number(tempInput.value || 0);
          await postSimState(temp, Math.round(speed));
        } catch(e){
          setBadge("Stream error: " + e.message, "warn");
          console.log(e);
        }
      }, 250);
    }

    tempInput.addEventListener("input", onChange);

    // Speed animation for realism
    setInterval(() => {
      speed += (Math.random() * 6 - 3);
      speed = Math.max(0, Math.min(140, speed));
      render();
    }, 900);

    render();
    onChange();
  </script>
</body>
</html>
